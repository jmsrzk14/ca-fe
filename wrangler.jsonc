{
    "name": "dots-ca-fe",
    "compatibility_date": "2024-01-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "main": ".vercel/output/static/_worker.js/index.js",
    "assets": {
        "directory": ".vercel/output/static",
        "binding": "ASSETS"
    },
    "vars": {
        "ENVIRONMENT": "production",
        "NEXT_PUBLIC_API_URL": "https://dots-ca-be-production.up.railway.app"
    }
}